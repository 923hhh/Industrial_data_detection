__pycache__/
*.py[cod]
*$py.class
.Python
env/
venv/
.env
.env.*
!.env.example
.venv/
pip-log.txt
pip-delete-this-directory.txt

# ========================
# 2. 数据库文件 (极其重要)
# ========================
